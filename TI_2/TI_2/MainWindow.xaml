<Window x:Class="TI_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шифрование LFSR-30"
        Height="600" Width="520"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="16" VerticalAlignment="Top">

        <Label Content="Начальное состояние регистра (30 бит):" FontWeight="Bold"/>
        <TextBox x:Name="SeedTextBox"
                 MaxLength="30"
                 Height="28"
                 TextChanged="SeedTextBox_TextChanged"/>
        <TextBlock x:Name="CounterTextBlock"
                   Foreground="Gray"
                   FontSize="11"
                   Margin="0,2,0,8"/>

        <Label Content="Файл для обработки:" FontWeight="Bold"/>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilePathTextBox"
                     Grid.Column="0"
                     IsReadOnly="True"
                     Height="28"
                     Margin="0,0,6,0"/>
            <Button x:Name="SelectFileButton"
                    Grid.Column="1"
                    Content="Обзор..."
                    Width="80" Height="28"
                    Click="SelectFileButton_Click"/>
        </Grid>

        <Button x:Name="ProcessButton"
                Content="Зашифровать / Расшифровать"
                Height="34"
                FontSize="14"
                Margin="0,4,0,4"
                Click="ProcessButton_Click"/>

        <ProgressBar x:Name="ProgressBar"
                     Height="14"
                     Margin="0,0,0,8"
                     Visibility="Collapsed"
                     IsIndeterminate="True"/>

        <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">
            <Separator Margin="0,4,0,8"/>

            <Label Content="Исходные данные (байты):" FontWeight="Bold"/>
            <TextBox x:Name="OrigOutput"
                     IsReadOnly="True"
                     Height="54"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     Background="#F5F5F5"/>

            <Label Content="Ключевой поток:" FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBox x:Name="KeyOutput"
                     IsReadOnly="True"
                     Height="54"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     Background="#F5F5F5"/>

            <Label Content="Результат:" FontWeight="Bold" Margin="0,6,0,0"/>
            <TextBox x:Name="ResultOutput"
                     IsReadOnly="True"
                     Height="54"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     Background="#FFFDE7"/>

            <Button x:Name="SaveButton"
                    Content="Сохранить результат"
                    Height="30"
                    Width="180"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0"
                    IsEnabled="False"
                    Click="SaveButton_Click"/>
        </StackPanel>

    </StackPanel>
</Window>